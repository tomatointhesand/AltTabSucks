{
  "manifest_version": 3,
  "name": "AltTabSucks",
  "version": "1.0.8",
  "description": "Hotkey based browser tab and application focus control management suite",
  "permissions": [
    "tabs",
    "windows",
    "storage"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "host_permissions": [
    "http://localhost:9876/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AltTabSucks",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
