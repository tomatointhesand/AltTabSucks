{
  "manifest_version": 3,
  "name": "AltTabSucks",
  "version": "1.0.13",
  "description": "ATS is the alt-tab of the future: a keyboard shortcut based solution for app-specific window focus control, profile-aware URL-based browser tab focus control, and more. Supports Brave, Chrome and Firefox at the moment. Windows only for now.",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "host_permissions": [
    "http://localhost:9876/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AltTabSucks",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "alttabsucks@piratesailing.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
